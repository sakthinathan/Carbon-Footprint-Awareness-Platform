# EcoSentinel Backend — Environment Variables
# Copy this to .env and fill in the values

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=EcoSentinel API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Firebase ─────────────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the entire JSON content as a single-line string, or provide the path to the JSON file
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-pro

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# Get from: https://upstash.com → Create Database → Redis URL
REDIS_URL=rediss://default:[password]@[endpoint].upstash.io:6379

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@ecosentinel.app

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
